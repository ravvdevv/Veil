{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "global-shortcut:default",
    "window-state:default",
    "shell:default",
    "os:default",
    "process:default",
    "fs:default",
    "clipboard-manager:default",
    "shell:allow-open"
  ]
}
